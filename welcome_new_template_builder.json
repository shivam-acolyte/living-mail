  "blocks": [
    {
      "id": "raw-amp-html",
      "type": "rawHtml",
      "props": {
        "html": "<!doctype html>\n<html ⚡4email data-css-strict>\n<head>\n  <meta charset=\"utf-8\">\n  <meta name=\"color-scheme\" content=\"light dark\">\n  <meta name=\"supported-color-schemes\" content=\"light dark\">\n  <script async src=\"https://cdn.ampproject.org/v0.js\"></script>\n  <script async custom-element=\"amp-form\" src=\"https://cdn.ampproject.org/v0/amp-form-0.1.js\"></script>\n  <script async custom-element=\"amp-carousel\" src=\"https://cdn.ampproject.org/v0/amp-carousel-0.2.js\"></script>\n  <style amp4email-boilerplate>body{visibility:hidden}</style>\n  <style amp-custom>\n    body{margin:0;background-color:#F4F6F8;font-family:'Segoe UI', system-ui, sans-serif;color:#0B0F3D}\n    .email-shell{width:500px;max-width:100%;margin:0 auto;background-color:#FFFFFF;padding:0}\n    .email-content{color:#0B0F3D}\n    a{color:#2F3FE4}\n    @media only screen and (max-width:480px) {\n      .email-shell{width:100%;max-width:100%}\n      .email-content{width:100%}\n    }\n  </style>\n</head>\n<body class=\"email-bg\">\n  <div class=\"email-shell email-content\">\n    \n    <!-- Header Logo -->\n    <div style=\"background: #161D83; padding: 0; max-width: 500px; margin: 0 auto;\">\n      <amp-img src=\"https://amp.acolyteliving.com/template-assets/images/livinglogo.png\" alt=\"Acolyte Living\" width=\"500\" height=\"63\" layout=\"responsive\"></amp-img>\n    </div>\n\n    <!-- Welcome Hero -->\n    <div style=\"background: #F8FAFF; padding: 32px 24px; text-align: center; font-family: 'Segoe UI', system-ui, sans-serif;\">\n      <div style=\"width: 80px; height: 80px; background: #161D83; border-radius: 50%; margin: 0 auto 20px; line-height: 80px; font-size: 36px;\">🎓</div>\n      <h1 style=\"margin: 0; margin-bottom: 12px; color: #0B0F3D; font-size: 32px; font-weight: 800; line-height: 1.2;\">Welcome to the Family,<br><span style=\"color: #2F3FE4;\">{{firstName}}</span>!</h1>\n      <p style=\"margin: 0; margin-bottom: 24px; color: #6B7280; font-size: 16px; line-height: 1.6; margin-left: auto; margin-right: auto; max-width: 480px;\">You are now part of <strong>50,000+ students</strong> who found their perfect home through Acolyte Living. Let us get you settled!</p>\n      <a href=\"https://acolyteliving.com/properties\" style=\"background: #2F3FE4; color: #ffffff; border-radius: 10px; padding: 14px 28px; font-weight: 700; font-size: 16px; display: inline-block; text-decoration: none;\">Explore Properties →</a>\n    </div>\n\n    <!-- Stats Bar -->\n    <div style=\"background: #161D83; padding: 24px; font-family: 'Segoe UI', system-ui, sans-serif;\">\n      <table role=\"presentation\" width=\"100%\" cellspacing=\"0\" cellpadding=\"0\" border=\"0\">\n        <tr>\n          <td align=\"center\" style=\"width: 25%;\">\n            <div style=\"font-size: 24px; font-weight: 800; color: #4F6BFF;\">250+</div>\n            <div style=\"font-size: 11px; color: #9CA3AF; font-weight: 600; text-transform: uppercase;\">Cities</div>\n          </td>\n          <td align=\"center\" style=\"width: 25%;\">\n            <div style=\"font-size: 24px; font-weight: 800; color: #4F6BFF;\">1,245</div>\n            <div style=\"font-size: 11px; color: #9CA3AF; font-weight: 600; text-transform: uppercase;\">Properties</div>\n          </td>\n          <td align=\"center\" style=\"width: 25%;\">\n            <div style=\"font-size: 24px; font-weight: 800; color: #4F6BFF;\">2k+</div>\n            <div style=\"font-size: 11px; color: #9CA3AF; font-weight: 600; text-transform: uppercase;\">Universities</div>\n          </td>\n          <td align=\"center\" style=\"width: 25%;\">\n            <div style=\"font-size: 24px; font-weight: 800; color: #4F6BFF;\">4.8★</div>\n            <div style=\"font-size: 11px; color: #9CA3AF; font-weight: 600; text-transform: uppercase;\">Rating</div>\n          </td>\n        </tr>\n      </table>\n    </div>\n\n    <!-- Journey Tracker Section -->\n    <div style=\"background-color: #ffffff; padding: 32px 24px; font-family: 'Segoe UI', system-ui, sans-serif;\">\n      <h2 style=\"margin: 0; margin-bottom: 8px; color: #0B0F3D; font-size: 22px; font-weight: 800; text-align: center;\">Your Journey Starts Here</h2>\n      <p style=\"margin: 0; margin-bottom: 28px; color: #6B7280; font-size: 14px; text-align: center;\">Complete these steps to find your dream accommodation</p>\n\n      <div style=\"max-width: 520px; margin: 0 auto;\">\n        <!-- Step 1: Done -->\n        <div style=\"background-color: #EEF1FF; border-radius: 12px; border-left: 4px solid #10B981; padding: 16px; margin-bottom: 16px;\">\n          <table role=\"presentation\" width=\"100%\" cellspacing=\"0\" cellpadding=\"0\" border=\"0\">\n            <tr>\n              <td style=\"width: 40px; vertical-align: top;\">\n                <div style=\"width: 32px; height: 32px; background: #10B981; color: #fff; border-radius: 50%; text-align: center; line-height: 32px; font-weight: 800; font-size: 14px;\">✓</div>\n              </td>\n              <td>\n                <p style=\"margin: 0; font-weight: 700; color: #0B0F3D; font-size: 15px;\">Account Created</p>\n                <p style=\"margin: 4px 0 0 0; color: #6B7280; font-size: 13px;\">Welcome aboard! Your profile is ready.</p>\n              </td>\n            </tr>\n          </table>\n        </div>\n\n        <!-- Step 2: Completed -->\n        <div style=\"background-color: #EEF1FF; border-radius: 12px; border-left: 4px solid #10B981; padding: 16px; margin-bottom: 16px;\">\n          <table role=\"presentation\" width=\"100%\" cellspacing=\"0\" cellpadding=\"0\" border=\"0\">\n            <tr>\n              <td style=\"width: 40px; vertical-align: top;\">\n                <div style=\"width: 32px; height: 32px; background: #10B981; color: #fff; border-radius: 50%; text-align: center; line-height: 32px; font-weight: 800; font-size: 14px;\">✓</div>\n              </td>\n              <td>\n                <p style=\"margin: 0; font-weight: 700; color: #0B0F3D; font-size: 15px;\">Profile Completed</p>\n                <p style=\"margin: 4px 0 0 0; color: #6B7280; font-size: 13px;\">Your details have been saved.</p>\n              </td>\n            </tr>\n          </table>\n        </div>\n\n        <!-- Step 3: Pending -->\n        <div style=\"background-color: #F8FAFC; border-radius: 12px; border-left: 4px solid #CBD5E1; padding: 16px;\">\n          <table role=\"presentation\" width=\"100%\" cellspacing=\"0\" cellpadding=\"0\" border=\"0\">\n            <tr>\n              <td style=\"width: 40px; vertical-align: top;\">\n                <div style=\"width: 32px; height: 32px; background: #9CA3AF; color: #fff; border-radius: 50%; text-align: center; line-height: 32px; font-weight: 800; font-size: 14px;\">3</div>\n              </td>\n              <td>\n                <p style=\"margin: 0; font-weight: 700; color: #0B0F3D; font-size: 15px;\">Find and Book</p>\n                <p style=\"margin: 4px 0 0 0; color: #6B7280; font-size: 13px;\">Browse verified properties and book in under 5 minutes.</p>\n              </td>\n            </tr>\n          </table>\n        </div>\n      </div>\n    </div>\n\n    <!-- Visible AMP Form Section (Placed below profile steps using amp-form with action-xhr) -->\n    <div style=\"background-color: #F8FAFF; padding: 32px 24px; font-family: 'Segoe UI', system-ui, sans-serif; text-align: center;\">\n      <div style=\"max-width: 480px; margin: 0 auto; background: #ffffff; border: 1px solid #E8ECFF; border-radius: 16px; padding: 24px; box-sizing: border-box;\">\n        <h3 style=\"margin: 0; margin-bottom: 6px; color: #0B0F3D; font-size: 18px; font-weight: 800;\">Update Your Preferences</h3>\n        <p style=\"margin: 0; margin-bottom: 20px; color: #6B7280; font-size: 13px;\">Tell us what you're looking for to refine matches.</p>\n        \n        <form method=\"post\" action-xhr=\"https://acolyteliving.com/api/profile\">\n          <fieldset style=\"border:none; padding:0; margin:0;\">\n            <input type=\"text\" name=\"destination\" placeholder=\"Destination City\" required style=\"color: #000000; border: 1px solid #0B0F3D; background: #ffffff; border-radius: 6px; padding: 10px 12px; font-size: 16px; width: 100%; box-sizing: border-box; margin-bottom: 12px;\">\n            <input type=\"text\" name=\"university\" placeholder=\"Your University\" required style=\"color: #000000; border: 1px solid #0B0F3D; background: #ffffff; border-radius: 6px; padding: 10px 12px; font-size: 16px; width: 100%; box-sizing: border-box; margin-bottom: 12px;\">\n            <input type=\"text\" name=\"budget\" placeholder=\"Weekly Budget (e.g. £150 - £250)\" required style=\"color: #000000; border: 1px solid #0B0F3D; background: #ffffff; border-radius: 6px; padding: 10px 12px; font-size: 16px; width: 100%; box-sizing: border-box; margin-bottom: 16px;\">\n            <button type=\"submit\" style=\"background: #2F3FE4; color: #ffffff; border: none; border-radius: 8px; padding: 12px 20px; font-size: 15px; font-weight: 700; width: 100%; cursor: pointer;\">Save Preferences</button>\n          </fieldset>\n          <div submitting><p style=\"color: #2F3FE4; font-size: 13px; margin-top: 10px;\">Saving...</p></div>\n          <div submit-success><p style=\"color: #10B981; font-size: 13px; margin-top: 10px;\">Preferences saved successfully!</p></div>\n          <div submit-error><p style=\"color: #DC2626; font-size: 13px; margin-top: 10px;\">Something went wrong. Try again.</p></div>\n        </form>\n      </div>\n    </div>\n\n    <!-- 4 Static Property Cards Section -->\n    <div style=\"background-color: #ffffff; padding: 32px 24px; font-family: 'Segoe UI', system-ui, sans-serif;\">\n      <h2 style=\"margin: 0; margin-bottom: 8px; color: #0B0F3D; font-size: 22px; font-weight: 800; text-align: center;\">Curated Accommodations</h2>\n      <p style=\"margin: 0; margin-bottom: 24px; color: #6B7280; font-size: 14px; text-align: center;\">Explore our top selected properties</p>\n\n      <div style=\"max-width: 520px; margin: 0 auto;\">\n        <table role=\"presentation\" width=\"100%\" cellspacing=\"0\" cellpadding=\"0\" border=\"0\">\n          <tr>\n            <td style=\"width: 50%; padding-right: 6px; vertical-align: top; padding-bottom: 12px;\">\n              <div style=\"background: #ffffff; border-radius: 12px; border: 1px solid #E8ECFF; overflow: hidden;\">\n                <amp-img src=\"https://amp.acolyteliving.com/template-assets/images/archviewhouse.avif\" alt=\"Arch View House\" width=\"230\" height=\"120\" layout=\"responsive\"></amp-img>\n                <div style=\"padding: 12px;\">\n                  <p style=\"margin: 0; color: #0B0F3D; font-size: 13px; font-weight: 700;\">Arch View House</p>\n                  <p style=\"margin: 2px 0 8px 0; color: #6B7280; font-size: 10px;\">Shared apartment designed to save money.</p>\n                  <table role=\"presentation\" width=\"100%\" cellspacing=\"0\" cellpadding=\"0\" border=\"0\">\n                    <tr>\n                      <td><span style=\"color: #2F3FE4; font-weight: 700; font-size: 13px;\">£189/wk</span></td>\n                      <td align=\"right\"><a href=\"https://acolyteliving.com/properties/uk/london/apartments-1486739\" style=\"background: #2F3FE4; color: #ffffff; border-radius: 4px; padding: 4px 8px; font-weight: 700; font-size: 10px; text-decoration: none; display: inline-block;\">View</a></td>\n                    </tr>\n                  </table>\n                </div>\n              </div>\n            </td>\n            <td style=\"width: 50%; padding-left: 6px; vertical-align: top; padding-bottom: 12px;\">\n              <div style=\"background: #ffffff; border-radius: 12px; border: 1px solid #E8ECFF; overflow: hidden;\">\n                <amp-img src=\"https://amp.acolyteliving.com/template-assets/images/pittodriestreet.avif\" alt=\"Pittodrie Street\" width=\"230\" height=\"120\" layout=\"responsive\"></amp-img>\n                <div style=\"padding: 12px;\">\n                  <p style=\"margin: 0; color: #0B0F3D; font-size: 13px; font-weight: 700;\">Pittodrie Street</p>\n                  <p style=\"margin: 2px 0 8px 0; color: #6B7280; font-size: 10px;\">Spacious twin rooms and communal spaces.</p>\n                  <table role=\"presentation\" width=\"100%\" cellspacing=\"0\" cellpadding=\"0\" border=\"0\">\n                    <tr>\n                      <td><span style=\"color: #2F3FE4; font-weight: 700; font-size: 13px;\">£149/wk</span></td>\n                      <td align=\"right\"><a href=\"https://acolyteliving.com/properties/uk/aberdeen/apartments-788373\" style=\"background: #2F3FE4; color: #ffffff; border-radius: 4px; padding: 4px 8px; font-weight: 700; font-size: 10px; text-decoration: none; display: inline-block;\">View</a></td>\n                    </tr>\n                  </table>\n                </div>\n              </div>\n            </td>\n          </tr>\n          <tr>\n            <td style=\"width: 50%; padding-right: 6px; vertical-align: top; padding-bottom: 12px;\">\n              <div style=\"background: #ffffff; border-radius: 12px; border: 1px solid #E8ECFF; overflow: hidden;\">\n                <amp-img src=\"https://amp.acolyteliving.com/template-assets/images/chapterhighburryII.avif\" alt=\"Chapter Highbury II\" width=\"230\" height=\"120\" layout=\"responsive\"></amp-img>\n                <div style=\"padding: 12px;\">\n                  <p style=\"margin: 0; color: #0B0F3D; font-size: 13px; font-weight: 700;\">Chapter Highbury II</p>\n                  <p style=\"margin: 2px 0 8px 0; color: #6B7280; font-size: 10px;\">Elevate your experience with panoramic views.</p>\n                  <table role=\"presentation\" width=\"100%\" cellspacing=\"0\" cellpadding=\"0\" border=\"0\">\n                    <tr>\n                      <td><span style=\"color: #2F3FE4; font-weight: 700; font-size: 13px;\">£353/wk</span></td>\n                      <td align=\"right\"><a href=\"https://acolyteliving.com/properties/uk/london/apartments-733730\" style=\"background: #2F3FE4; color: #ffffff; border-radius: 4px; padding: 4px 8px; font-weight: 700; font-size: 10px; text-decoration: none; display: inline-block;\">View</a></td>\n                    </tr>\n                  </table>\n                </div>\n              </div>\n            </td>\n            <td style=\"width: 50%; padding-left: 6px; vertical-align: top; padding-bottom: 12px;\">\n              <div style=\"background: #ffffff; border-radius: 12px; border: 1px solid #E8ECFF; overflow: hidden;\">\n                <amp-img src=\"https://amp.acolyteliving.com/template-assets/images/chapteroldstreet.avif\" alt=\"Chapter Old Street\" width=\"230\" height=\"120\" layout=\"responsive\"></amp-img>\n                <div style=\"padding: 12px;\">\n                  <p style=\"margin: 0; color: #0B0F3D; font-size: 13px; font-weight: 700;\">Chapter Old Street</p>\n                  <p style=\"margin: 2px 0 8px 0; color: #6B7280; font-size: 10px;\">Located right across university gates.</p>\n                  <table role=\"presentation\" width=\"100%\" cellspacing=\"0\" cellpadding=\"0\" border=\"0\">\n                    <tr>\n                      <td><span style=\"color: #2F3FE4; font-weight: 700; font-size: 13px;\">£284/wk</span></td>\n                      <td align=\"right\"><a href=\"https://acolyteliving.com/properties/uk/london/apartments-1420102\" style=\"background: #2F3FE4; color: #ffffff; border-radius: 4px; padding: 4px 8px; font-weight: 700; font-size: 10px; text-decoration: none; display: inline-block;\">View</a></td>\n                    </tr>\n                  </table>\n                </div>\n              </div>\n            </td>\n          </tr>\n        </table>\n      </div>\n    </div>\n\n    <!-- Trending Properties Carousel (Using amp-carousel) -->\n    <div style=\"background-color: #F8FAFF; padding: 32px 24px; font-family: 'Segoe UI', system-ui, sans-serif;\">\n      <h2 style=\"margin: 0; margin-bottom: 8px; color: #0B0F3D; font-size: 22px; font-weight: 800; text-align: center;\">Trending Properties</h2>\n      <p style=\"margin: 0; margin-bottom: 24px; color: #6B7280; font-size: 14px; text-align: center;\">Students are loving these verified properties right now</p>\n\n      <div style=\"max-width: 520px; margin: 0 auto; border-radius: 16px; overflow: hidden; border: 1px solid #E8ECFF; background: #ffffff;\">\n        <amp-carousel width=\"520\" height=\"360\" layout=\"responsive\" type=\"slides\" autoplay delay=\"4000\">\n          <div>\n            <amp-img src=\"https://amp.acolyteliving.com/template-assets/images/iqbankside.avif\" alt=\"IQ Kingstone\" width=\"520\" height=\"240\" layout=\"responsive\"></amp-img>\n            <div style=\"padding: 16px;\">\n              <table role=\"presentation\" width=\"100%\" cellspacing=\"0\" cellpadding=\"0\" border=\"0\">\n                <tr>\n                  <td>\n                    <p style=\"margin: 0; color: #0B0F3D; font-size: 16px; font-weight: 800;\">IQ Kingstone</p>\n                    <p style=\"margin: 4px 0 0 0; color: #6B7280; font-size: 12px;\">⭐ 4.8 · 0.4 mi walk from Southwark College</p>\n                  </td>\n                  <td align=\"right\">\n                    <div style=\"background: linear-gradient(rgb(22, 29, 131) 0%, rgb(47, 63, 228) 100%); color: #fff; padding: 6px 14px; border-radius: 20px; font-size: 13px; font-weight: 700; display: inline-block;\">£450/wk</div>\n                  </td>\n                </tr>\n              </table>\n            </div>\n          </div>\n          <div>\n            <amp-img src=\"https://amp.acolyteliving.com/template-assets/images/chapterlondonbridge.avif\" alt=\"Chapter London Bridge\" width=\"520\" height=\"240\" layout=\"responsive\"></amp-img>\n            <div style=\"padding: 16px;\">\n              <table role=\"presentation\" width=\"100%\" cellspacing=\"0\" cellpadding=\"0\" border=\"0\">\n                <tr>\n                  <td>\n                    <p style=\"margin: 0; color: #0B0F3D; font-size: 16px; font-weight: 800;\">Chapter London Bridge</p>\n                    <p style=\"margin: 4px 0 0 0; color: #6B7280; font-size: 12px;\">⭐ 4.7 · 5 min to King's College London</p>\n                  </td>\n                  <td align=\"right\">\n                    <div style=\"background: linear-gradient(rgb(22, 29, 131) 0%, rgb(47, 63, 228) 100%); color: #fff; padding: 6px 14px; border-radius: 20px; font-size: 13px; font-weight: 700; display: inline-block;\">£485/wk</div>\n                  </td>\n                </tr>\n              </table>\n            </div>\n          </div>\n        </amp-carousel>\n      </div>\n\n      <div style=\"text-align: center; margin-top: 20px;\">\n        <a href=\"https://acolyteliving.com/properties\" style=\"background: linear-gradient(rgb(22, 29, 131) 0%, rgb(47, 63, 228) 100%); color: #ffffff; border: none; border-radius: 10px; padding: 14px 28px; font-weight: 700; font-size: 15px; display: inline-block; text-decoration: none;\">View All Properties →</a>\n      </div>\n    </div>\n\n    <!-- Trust Stats -->\n    <div style=\"background-color: #ffffff; padding: 32px 24px; font-family: 'Segoe UI', system-ui, sans-serif;\">\n      <h2 style=\"margin: 0; margin-bottom: 24px; color: #0B0F3D; font-size: 22px; font-weight: 800; text-align: center;\">Why Students Trust Us</h2>\n      <div style=\"display: flex; flex-wrap: wrap; gap: 16px; justify-content: center;\">\n        <div style=\"background: #F8FAFF; border-radius: 16px; padding: 20px; border: 1px solid #E8ECFF; text-align: center; width: 150px; box-sizing: border-box;\">\n          <div style=\"font-size: 32px; margin-bottom: 8px;\">🔒</div>\n          <p style=\"margin: 0; font-weight: 700; color: #0B0F3D; font-size: 14px;\">100% Verified</p>\n          <p style=\"margin: 0; margin-top: 12px; color: #6B7280; font-size: 12px;\">Every property checked</p>\n        </div>\n        <div style=\"background: #F8FAFF; border-radius: 16px; padding: 20px; border: 1px solid #E8ECFF; text-align: center; width: 150px; box-sizing: border-box;\">\n          <div style=\"font-size: 32px; margin-bottom: 8px;\">💰</div>\n          <p style=\"margin: 0; font-weight: 700; color: #0B0F3D; font-size: 14px;\">Price Match</p>\n          <p style=\"margin: 0; margin-top: 12px; color: #6B7280; font-size: 12px;\">Best price guarantee</p>\n        </div>\n      </div>\n    </div>\n\n    <!-- Support CTA -->\n    <div style=\"background: linear-gradient(rgb(22, 29, 131) 0%, rgb(47, 63, 228) 100%); padding: 32px 24px; text-align: center; font-family: 'Segoe UI', system-ui, sans-serif;\">\n      <h2 style=\"margin: 0; margin-bottom: 8px; color: #ffffff; font-size: 20px; font-weight: 800;\">Need Help Finding Your Home?</h2>\n      <p style=\"margin: 0; margin-bottom: 20px; color: #A5B4FC; font-size: 14px;\">Our student support team is online 24/7</p>\n      <div>\n        <a href=\"https://chat.whatsapp.com/JcWX8UoVVO83P2BQsB5ZrE\" style=\"background: #25d366; color: #ffffff; border-radius: 10px; padding: 12px 24px; font-weight: 700; font-size: 14px; display: inline-block; text-decoration: none; margin: 4px;\">💬 WhatsApp Us</a>\n        <a href=\"https://api.whatsapp.com/send?phone=447541903957\" style=\"background: #ffffff; color: #161D83; border-radius: 10px; padding: 12px 24px; font-weight: 700; font-size: 14px; display: inline-block; text-decoration: none; margin: 4px;\">📞 Call Support</a>\n      </div>\n    </div>\n\n    <!-- Footer with Social Media Logos -->\n    <div style=\"background-color: #F8FAFF; padding: 24px; text-align: center; font-family: 'Segoe UI', system-ui, sans-serif;\">\n      <div style=\"text-align: center; margin-bottom: 16px;\">\n        <table role=\"presentation\" align=\"center\" cellspacing=\"0\" cellpadding=\"0\" border=\"0\" style=\"margin: 0 auto;\">\n          <tr>\n            <td style=\"padding: 0 6px;\">\n              <a href=\"https://www.instagram.com/acolyte.living/\" target=\"_blank\" style=\"display: block; width: 32px; height: 32px; background: #ffffff; border-radius: 50%; text-align: center; line-height: 32px; text-decoration: none; border: 1px solid #E8ECFF;\">\n                <amp-img src=\"https://cdn-icons-png.flaticon.com/512/733/733558.png\" alt=\"Instagram\" width=\"14\" height=\"14\" layout=\"fixed\" style=\"vertical-align: middle; display: inline-block;\"></amp-img>\n              </a>\n            </td>\n            <td style=\"padding: 0 6px;\">\n              <a href=\"https://www.facebook.com/acolyteliving.uk/\" target=\"_blank\" style=\"display: block; width: 32px; height: 32px; background: #ffffff; border-radius: 50%; text-align: center; line-height: 32px; text-decoration: none; border: 1px solid #E8ECFF;\">\n                <amp-img src=\"https://cdn-icons-png.flaticon.com/512/733/733547.png\" alt=\"Facebook\" width=\"14\" height=\"14\" layout=\"fixed\" style=\"vertical-align: middle; display: inline-block;\"></amp-img>\n              </a>\n            </td>\n            <td style=\"padding: 0 6px;\">\n              <a href=\"https://uk.linkedin.com/company/acolyte-living\" target=\"_blank\" style=\"display: block; width: 32px; height: 32px; background: #ffffff; border-radius: 50%; text-align: center; line-height: 32px; text-decoration: none; border: 1px solid #E8ECFF;\">\n                <amp-img src=\"https://cdn-icons-png.flaticon.com/512/733/733561.png\" alt=\"LinkedIn\" width=\"14\" height=\"14\" layout=\"fixed\" style=\"vertical-align: middle; display: inline-block;\"></amp-img>\n              </a>\n            </td>\n          </tr>\n        </table>\n      </div>\n      <p style=\"margin: 0; margin-bottom: 8px; color: #6B7280; font-size: 12px;\">© 2026 Acolyte Living. All rights reserved.</p>\n      <div style=\"display: flex; justify-content: center; gap: 16px;\">\n        <a href=\"https://acolyteliving.com/privacy\" style=\"color: #6B7280; text-decoration: none; font-size: 11px;\">Privacy Policy</a>\n        <a href=\"https://acolyteliving.com/terms\" style=\"color: #6B7280; text-decoration: none; font-size: 11px;\">Terms of Service</a>\n      </div>\n      <div style=\"font-family:'Segoe UI', system-ui, sans-serif;font-size:12px;color:#6b7280;text-align:center;margin:20px 0 0\">\n        <a href=\"https://acolyteliving.com/unsubscribe\" target=\"_blank\" style=\"color:#6B7280;text-decoration:underline\">Unsubscribe</a>\n      </div>\n    </div>\n\n  </div>\n</body>\n</html>\n"
      }
    }
  ]
