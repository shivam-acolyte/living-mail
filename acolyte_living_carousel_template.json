    {
      "id": "offer-form-block",
      "type": "rawHtml",
      "props": {
        "html": "<div class=\"offer-form-section\" [class]=\"showOfferForm ? 'offer-form-section is-visible' : 'offer-form-section'\" hidden [hidden]=\"!showOfferForm\" style=\"margin: 0 20px 24px;\">\n      <div style=\"background: #ffffff; border-radius: 20px; overflow: hidden; box-shadow: 0 8px 32px rgba(0,0,0,0.15);\">\n        <form action-xhr=\"https://your-endpoint.com/submit-offer\" method=\"POST\" style=\"margin:0;\">\n          <div class=\"form-content-wrapper\">\n            <div class=\"offer-form-header\" style=\"position: relative; padding: 28px 24px 20px; text-align: center; background: linear-gradient(135deg, #4338ca, #1e1b4b);\">\n              <div style=\"font-size: 40px; margin-bottom: 8px;\">🎁</div>\n              <h3 style=\"margin: 0 0 6px 0; font-size: 22px; color: #ffffff; font-weight: 700;\">Book Your Student Accommodation</h3>\n              <p style=\"margin: 0; font-size: 13px; color: rgba(255,255,255,0.85);\">Save up to £500 on your booking!</p>\n              <button type=\"button\" on=\"tap:AMP.setState({ showOfferForm: false })\" style=\"position:absolute;top:16px;right:16px;background:rgba(255,255,255,0.2);border:none;color:#ffffff;width:32px;height:32px;border-radius:50%;font-size:18px;cursor:pointer;\">✕</button>\n            </div>\n            <div style=\"padding: 24px;\">\n              <input type=\"text\" name=\"full_name\" placeholder=\"Full Name\" style=\"width: 100%; padding: 14px 16px; margin-bottom: 14px; border: 1px solid #e5e7eb; border-radius: 10px; font-size: 14px; box-sizing: border-box; background: #f9fafb; color: #111827;\">\n              <div style=\"display: flex; gap: 10px; margin-bottom: 14px;\">\n                <input type=\"text\" name=\"country_code\" value=\"+44\" aria-label=\"Country code\" style=\"width: 70px; padding: 14px 10px; border: 1px solid #e5e7eb; border-radius: 10px; font-size: 14px; background: #f9fafb; color: #111827; flex-shrink: 0; text-align: center; box-sizing: border-box;\">\n                <input type=\"tel\" name=\"mobile\" placeholder=\"Mobile Number *\" required style=\"flex: 1; padding: 14px 16px; border: 1px solid #e5e7eb; border-radius: 10px; font-size: 14px; box-sizing: border-box; background: #f9fafb; color: #111827;\">\n              </div>\n              <input type=\"text\" name=\"best_time\" placeholder=\"Best Time to Connect\" style=\"width: 100%; padding: 14px 16px; margin-bottom: 20px; border: 1px solid #e5e7eb; border-radius: 10px; font-size: 14px; box-sizing: border-box; background: #f9fafb; color: #111827;\">\n              <button type=\"submit\" style=\"width: 100%; padding: 16px; background: linear-gradient(135deg, #4338ca, #1e1b4b); color: #ffffff; border: none; border-radius: 12px; font-size: 16px; font-weight: 700; font-family: Helvetica, Arial, sans-serif; box-shadow: 0 4px 16px rgba(67, 56, 202, 0.3);\">Unlock Offer →</button>\n              <p style=\"margin: 14px 0 0 0; font-size: 11px; color: #9ca3af; text-align: center;\">🔒 Your information is secure and never shared with third parties.</p>\n            </div>\n          </div>\n          <div submitting style=\"text-align: center; padding: 80px 30px;\">\n            <div style=\"display: inline-block; width: 44px; height: 44px; border: 4px solid #e5e7eb; border-top-color: #4338ca; border-radius: 50%;\"></div>\n            <p style=\"color: #6b7280; margin-top: 16px; font-size: 15px;\">Submitting your request...</p>\n          </div>\n          <div submit-success style=\"text-align: center; padding: 40px 30px;\">\n            <div style=\"font-size: 56px; margin-bottom: 16px;\">🎉</div>\n            <h3 style=\"color: #111827; margin: 0 0 8px 0; font-size: 24px; font-weight: 700;\">Thank You!</h3>\n            <p style=\"color: #6b7280; margin: 0 0 24px 0; font-size: 14px; line-height: 1.5;\">Our team will contact you within 24 hours with your exclusive offer.</p>\n            <div style=\"background: #f5f3ff; border-radius: 12px; padding: 20px; margin-bottom: 24px;\">\n              <p style=\"margin: 0 0 12px 0; font-size: 13px; color: #4338ca; font-weight: 600;\">While you wait, explore the property:</p>\n              <a href=\"https://acolyteliving.com/properties/uk/london/apartments-1717485\" target=\"_blank\" style=\"display: inline-block; padding: 14px 32px; background: linear-gradient(135deg, #4338ca, #1e1b4b); color: #ffffff; text-decoration: none; border-radius: 12px; font-size: 15px; font-weight: 700; box-shadow: 0 4px 12px rgba(67, 56, 202, 0.3);\">Visit Website →</a>\n            </div>\n            <button type=\"button\" on=\"tap:offer-form-block.hide\" style=\"background: none; border: none; color: #9ca3af; font-size: 13px; text-decoration: underline;\">Close this window</button>\n          </div>\n          <div submit-error style=\"text-align: center; padding: 50px 30px;\">\n            <div style=\"font-size: 48px; margin-bottom: 12px;\">⚠️</div>\n            <h3 style=\"color: #111827; margin: 0 0 8px 0; font-size: 20px;\">Oops! Something went wrong</h3>\n            <p style=\"color: #6b7280; margin: 0 0 20px 0; font-size: 14px;\">Please try again or contact us directly.</p>\n            <a href=\"mailto:support@acolyteliving.com\" style=\"color: #4338ca; text-decoration: none; font-size: 14px; font-weight: 600;\">support@acolyteliving.com</a>\n          </div>\n        </form>\n      </div>\n    </div>"
      }
