    {
      "id": "testimonials-block",
      "type": "rawHtml",
      "props": {
        "html": "<div style=\"margin: 20px 20px 24px; padding: 20px; background: #f8fafc;background-image:linear-gradient(135deg,#4338ca,#1e1b4b); border-radius: 16px; border: 1px solid #e2e8f0; font-family: Helvetica, Arial, sans-serif;\">\n      <h3 style=\"margin: 0 0 16px 0; font-size: 16px; color: #ffffff; text-align: center; font-weight: 700;\">💬 What Students Say</h3>\n      <div style=\"background: white; border-radius: 12px; padding: 16px; border: 1px solid #e5e7eb; margin-bottom: 12px;\">\n        <div style=\"display:flex;align-items:center;gap:10px;margin-bottom:8px;\">\n          <div style=\"width:30px;height:30px;background:linear-gradient(135deg,#4338ca,#2F3FE4);border-radius:50%;display:flex;align-items:center;justify-content:center;color:white;font-size:14px;font-weight:700;\">S</div>\n          <div>\n            <p style=\"margin:0;font-size:13px;font-weight:700;color:#111827;\">Sarah M.</p>\n            <p style=\"margin:0;font-size:11px;color:#6b7280;\">University of West London</p>\n          </div>\n          <span style=\"margin-left:auto;color:#f59e0b;\">★★★★★</span>\n        </div>\n        <p style=\"margin:0;font-size:13px;color:#4b5563;line-height:1.5;\">\"The rooftop is absolutely amazing for summer BBQs. Best decision I made for my student accommodation!\"</p>\n      </div>\n      <div style=\"background: white; border-radius: 12px; padding: 16px; border: 1px solid #e5e7eb;\">\n        <div style=\"display:flex;align-items:center;gap:10px;margin-bottom:8px;\">\n          <div style=\"width:30px;height:30px;background:linear-gradient(135deg,#2F3FE4,#161D83);border-radius:50%;display:flex;align-items:center;justify-content:center;color:white;font-size:14px;font-weight:700;\">J</div>\n          <div>\n            <p style=\"margin:0;font-size:13px;font-weight:700;color:#111827;\">James K.</p>\n            <p style=\"margin:0;font-size:11px;color:#6b7280;\">Richmond American University</p>\n          </div>\n          <span style=\"margin-left:auto;color:#f59e0b;\">★★★★★</span>\n        </div>\n        <p style=\"margin:0;font-size:13px;color:#4b5563;line-height:1.5;\">\"15 min bus to campus. The gym and study rooms are game-changers. Staff are super helpful too!\"</p>\n      </div>\n    </div>"
      }
