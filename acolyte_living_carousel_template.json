ext-align:center;width:100%;font-family:Helvetica, Arial, sans-serif;border:none;\">Enquire Now  →</button>\n          </div>\n        </div>\n      </div>\n      <!-- Slide 2: iq -->\n      <div>\n        <div style=\"background-color:#ffffff;border:1px solid #e0e0e0;border-radius:16px;overflow:hidden;margin:0 10px;text-align:left;box-sizing:border-box;font-family:Helvetica, Arial, sans-serif; position:relative;\">\n          <div style=\"position:relative;\">\n            <amp-img src=\"https://amp.startupflora.com/template-assets/images/iqcity.webp\" alt=\"iq city\" width=\"500\" height=\"220\" layout=\"responsive\"></amp-img>\n            <div class=\"discount-badge\" style=\"position:absolute;top:12px;right:12px;background:linear-gradient(to right, #BF953F, #FCF6BA, #B38728, #FBF5B7, #AA771C);color:#1A1A1A;padding:8px 14px;border-radius:10px;font-size:13px;font-weight:1000;text-align:center;line-height:1.3;box-shadow:0 4px 12px rgba(239, 68, 68, 0.4);z-index:10;\">\n              <span style=\"display:block;font-size:10px;font-weight:600;opacity:0.9;text-transform:uppercase;letter-spacing:0.5px;\">Get Up To</span>\n              £500 OFF\n            </div>\n          </div>\n          <div style=\"padding:20px;box-sizing:border-box\">\n            <h3 style=\"font-size:18px;font-weight:bold;margin:0 0 5px 0;color:#111827;font-family:Helvetica, Arial, sans-serif\">IQ City London</h3>\n            <p style=\"font-size:13.5px;color:#9aa1ac;margin:0 0 10px 0;font-family:Helvetica, Arial, sans-serif\">📍11 Bastwick Street, London </p>\n            <p style=\"font-size:20px;color:#4338ca;font-weight:bold;margin:0 0 20px 0;font-family:Helvetica, Arial, sans-serif\">Starting from £249/week</p>\n            <button on=\"tap:AMP.setState({ showOfferForm: true })\" style=\"display:block;box-sizing:border-box;background:linear-gradient(135deg,#4338ca,#1e1b4b);color:#ffffff;text-decoration:none;padding:14px;border-radius:12px;font-size:15.5px;font-weight:bold;text-align:center;width:100%;font-family:Helvetica, Arial, sans-serif;border:none;\">Enquire Now  →</button>\n          </div>\n        </div>\n      </div>\n      <!-- Slide 3: iQ Will Wyatt Court -->\n      <div>\n        <div style=\"background-color:#ffffff;border:1px solid #e0e0e0;border-radius:16px;overflow:hidden;margin:0 10px;text-align:left;box-sizing:border-box;font-family:Helvetica, Arial, sans-serif; position:relative;\">\n          <div style=\"position:relative;\">\n            <amp-img src=\"https://amp.startupflora.com/template-assets/images/iqwaytt.webp\" alt=\"iQ Will Wyatt Court\" width=\"500\" height=\"220\" layout=\"responsive\"></amp-img>\n            <div class=\"discount-badge\" style=\"position:absolute;top:12px;right:12px;background:linear-gradient(to right, #BF953F, #FCF6BA, #B38728, #FBF5B7, #AA771C);color:#1A1A1A;padding:8px 14px;border-radius:10px;font-size:13px;font-weight:1000;text-align:center;line-height:1.3;box-shadow:0 4px 12px rgba(239, 68, 68, 0.4);z-index:10;\">\n              <span style=\"display:block;font-size:10px;font-weight:600;opacity:0.9;text-transform:uppercase;letter-spacing:0.5px;\">Get Up To</span>\n              £500 OFF\n            </div>\n          </div>\n          <div style=\"padding:20px;box-sizing:border-box\">\n            <h3 style=\"font-size:18px;font-weight:bold;margin:0 0 5px 0;color:#111827;font-family:Helvetica, Arial, sans-serif\">iQ Will Wyatt Court</h3>\n            <p style=\"font-size:13.5px;color:#9aa1ac;margin:0 0 10px 0;font-family:Helvetica, Arial, sans-serif\">📍168 Pitfield Street, London</p>\n            <p style=\"font-size:20px;color:#4338ca;font-weight:bold;margin:0 0 20px 0;font-family:Helvetica, Arial, sans-serif\">Starting from £400/week</p>\n            <button on=\"tap:AMP.setState({ showOfferForm: true })\" style=\"display:block;box-sizing:border-box;background:linear-gradient(135deg,#4338ca,#1e1b4b);color:#ffffff;text-decoration:none;padding:14px;border-radius:12px;font-size:15.5px;font-weight:bold;text-align:center;width:100%;font-family:Helvetica, Arial, sans-serif;border:none;\">Enquire Now  →</button>\n          </div>\n        </div>\n      </div>\n    </amp-carousel>"
      }
